<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña - IMC+</title>
    <link rel="icon" type="image/png" href="/css/images/icon.png">
    
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        
        /* 1. Fondo azul oscuro de seguridad */
        html {
            background-color: #0F172A;
        }

        body {
            font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
            min-height:100vh;
            display:flex;
            justify-content: center;
            align-items: center;
            overflow-x:hidden;
        }

        /* 2. Capa fija independiente para el fondo */
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -1; 
            background-color: #0F172A;
            background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/css/images/logbackground.png');
            background-position: center center;
            background-repeat: no-repeat;
            background-size: cover;
        }
        
        @keyframes loginFade { from{opacity:0;transform:translateY(40px);} to{opacity:1;transform:translateY(0);} }
        @keyframes fadeOut { from {opacity: 1;} to {opacity: 0;} }
        
        /* Botón Regresar con Borde Blanco */
        .btn-regresar { 
            position:absolute; 
            top:30px; 
            left:30px; 
            padding:8px 16px; 
            border: 2px solid #ffffff; 
            color: #ffffff; 
            border-radius:8px; 
            text-decoration:none; 
            font-weight:700; 
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 8px;
            transition:0.3s; 
            z-index: 10;
            background: transparent;
        }
        .btn-regresar:hover { 
            background: rgba(255, 255, 255, 0.1); 
            color:#0EA5E9; 
            border-color: #0EA5E9;
            transform:translateX(-5px); 
        }

        /* Tarjeta Glassmorphism Premium */
        .login-card { 
            background: rgba(15, 23, 42, 0.7); 
            backdrop-filter: blur(10px); 
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05); 
            padding:55px; 
            border-radius:22px; 
            width: 100%; 
            max-width: 480px; 
            text-align:center; 
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
            animation:loginFade 0.6s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 0 20px;
        }
        
        .form-title { color:white; font-size:1.8rem; font-weight:900; margin-bottom:5px; }
        .subtitle-text { color:#93c5fd; font-size:0.9rem; font-weight:700; margin-bottom:25px; }
        
        /* Alertas de Éxito y Error */
        .alert-box { width: 100%; transition: opacity 0.5s ease; }
        .error-alert { background: #fef2f2; color: #dc2626; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; font-weight: 700; border: 1px solid #fecaca; }
        .success-alert { background: #d1fae5; color: #059669; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; font-weight: 700; border: 1px solid #a7f3d0; }

        .input-group { position:relative; margin-bottom:25px; width: 100%; display: flex; align-items: center; }
        
        /* Inputs oscuros para el cristal */
        .input-group input { width:100%; padding:16px 14px; border-radius:10px; border:1px solid #1E293B; background:#0F172A; color:white; font-weight:600; outline:none; transition:0.3s; font-size: 1rem; }
        .input-group input:focus { border-color:#0EA5E9; box-shadow:0 0 0 4px rgba(14, 165, 233, 0.1); }
        
        .input-group label { position:absolute; left:14px; top:16px; color:#94A3B8; font-size:14px; transition:0.3s; pointer-events:none; }
        .input-group input:focus + label, .input-group input:not(:placeholder-shown) + label { top:-8px; left:12px; background:#0F172A; padding:0 6px; font-size:12px; color:#0EA5E9; font-weight: 700; border-radius: 4px; }
        
        /* Ojo de Contraseña SVG */
        .toggle-password { 
            position: absolute; 
            right: 15px; 
            cursor: pointer; 
            color: #94A3B8; 
            transition: color 0.3s ease; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            width: 24px; 
            height: 24px; 
        }
        .toggle-password:hover { color: #0EA5E9; }

        .btn-login { width:100%; padding:16px; background:#0EA5E9; border:none; border-radius:10px; color:white; font-weight:800; font-size:16px; cursor:pointer; transition:0.3s; margin-top:5px; text-transform: uppercase; letter-spacing: 1px;}
        .btn-login:hover { background: #0284c7; transform:translateY(-2px); box-shadow: 0 10px 20px rgba(14, 165, 233, 0.3); }
        
        .footer-links { width: 100%; font-size: 0.95rem; color: #94A3B8; margin-top: 20px; }
        .footer-links a { color:#0EA5E9; text-decoration:none; font-weight:800; display:inline-block; }
        .footer-links a:hover { color: #0284c7; text-decoration: underline; }

        /* RESPONSIVO */
        @media(max-width: 480px) {
            body { height: auto; overflow-y: auto; padding: 90px 0 40px 0; }
            .login-card { padding: 35px 20px; border-radius: 16px; margin: 20px auto; }
            .form-title { font-size: 1.6rem; }
            .input-group input { padding: 14px 12px; }
            .btn-login { padding: 14px; }
            .btn-regresar { top: 20px; left: 20px; }
        }
    </style>
</head>
<body>

<a href="/login" class="btn-regresar">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
    </svg>
    Regresar
</a>

<div class="login-card">
    <h2 class="form-title">RECUPERAR ACCESO</h2>
    <p class="subtitle-text">Ingresa tus datos para restablecer tu cuenta</p>

    <div id="alertContainer" class="alert-box">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-alert">⚠️ <%= error %></div>
        <% } %>
        
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="success-alert">✅ <%= success %></div>
        <% } %>
    </div>

    <form action="/recuperar" method="POST" style="width: 100%;">
        <div class="input-group">
            <input type="email" name="email" placeholder=" " required>
            <label>Correo electrónico</label>
        </div>
        <div class="input-group">
            <input type="password" name="newPassword" id="passwordInput" placeholder=" " required>
            <label>Nueva contraseña</label>
            <div class="toggle-password" id="togglePassword">
                <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                </svg>
                <svg id="eyeSlashIcon" style="display: none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l-.708.709z"/>
                    <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
                    <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/>
                </svg>
            </div>
        </div>
        <button type="submit" class="btn-login">ACTUALIZAR CONTRASEÑA</button>
    </form>

    <div class="footer-links">
        ¿Ya recordaste tu contraseña? <a href="/login">Inicia sesión aquí</a>
    </div>
</div>

<script>
    // Mostrar/Ocultar Contraseña
    const togglePassword = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('passwordInput');
    const eyeIcon = document.getElementById('eyeIcon');
    const eyeSlashIcon = document.getElementById('eyeSlashIcon');

    togglePassword.addEventListener('click', function () {
        const isPassword = passwordInput.getAttribute('type') === 'password';
        
        if(isPassword) {
            passwordInput.setAttribute('type', 'text');
            eyeIcon.style.display = 'none';
            eyeSlashIcon.style.display = 'block';
        } else {
            passwordInput.setAttribute('type', 'password');
            eyeIcon.style.display = 'block';
            eyeSlashIcon.style.display = 'none';
        }
    });

    // Ocultar la alerta automáticamente después de 3 segundos
    document.addEventListener("DOMContentLoaded", function() {
        const alertBox = document.getElementById('alertContainer');
        // Solo ejecuta el timer si hay algún contenido dentro del contenedor de alertas
        if (alertBox && alertBox.innerHTML.trim() !== '') {
            setTimeout(() => {
                alertBox.style.opacity = '0';
                setTimeout(() => {
                    alertBox.style.display = 'none';
                }, 500); // Espera a que termine la transición de opacidad antes de ocultarlo
            }, 3000); // 3000ms = 3 segundos
        }
    });
</script>

</body>
</html>