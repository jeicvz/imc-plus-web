<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login - IMC+</title>
<link rel="icon" type="image/png" href="/css/images/icon.png">
<script src="https://accounts.google.com/gsi/client" async defer></script>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { 
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
    height: 100vh; 
    /* Fondo con tu imagen y un filtro negro neutro suave, SIN el tono azul */
    background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/css/images/logbackground.png') no-repeat center center fixed;
    background-size: cover;
    display: flex; 
    overflow: hidden; 
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Botón Regresar (CON BORDE BLANCO) */
.btn-regresar { 
    position: absolute; 
    top: 30px; 
    left: 30px; 
    padding: 8px 16px; 
    color: #ffffff; 
    text-decoration: none; 
    font-weight: 700; 
    transition: all 0.3s ease; 
    z-index: 10; 
    font-size: 0.95rem; 
    display: flex; 
    align-items: center; 
    gap: 8px;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    border: 2px solid #ffffff; /* Borde blanco agregado */
    border-radius: 8px;
    background: transparent;
}
.btn-regresar:hover { 
    color: #0EA5E9; 
    border-color: #0EA5E9;
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(-5px); 
}

.main-split { display: flex; width: 100%; height: 100%; }

/* Texto Izquierda (Vuelve a blanco con sombra para destacar sobre la imagen) */
.left-side { 
    flex: 1; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    padding: 100px; 
    z-index: 5; 
}
.left-side h1 { 
    font-size: 4rem; 
    font-weight: 900; 
    margin-bottom: 20px; 
    color: #ffffff;
    letter-spacing: -1px;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
}
.left-side p { 
    font-size: 1.15rem; 
    max-width: 500px; 
    line-height: 1.6; 
    color: #f8fafc; 
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
}

.right-side { 
    flex: 1; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    z-index: 5; 
    padding: 20px; 
}

/* Tarjeta Glassmorphism Azul Restaurada */
.login-card { 
    background: rgba(15, 23, 42, 0.7); 
    backdrop-filter: blur(10px); 
    -webkit-backdrop-filter: blur(10px); 
    border: 1px solid rgba(255, 255, 255, 0.05); 
    padding: 55px; 
    border-radius: 20px; 
    width: 100%; 
    max-width: 480px; 
    text-align: center; 
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4); 
    animation: fadeUp 0.6s ease; 
}
.login-card:hover { transform: translateY(-3px); transition: transform 0.4s ease; }

.form-title { color: #ffffff; font-size: 2rem; font-weight: 900; margin-bottom: 5px; } /* Letra blanca */
.subtitle-text { color: #93c5fd; font-size: 14px; font-weight: 600; margin-bottom: 25px; } /* Letra celeste */

/* Alerta de Error Clara */
.error-alert { 
    background: #fef2f2; 
    color: #dc2626; 
    padding: 12px; 
    border-radius: 8px; 
    margin-bottom: 20px; 
    font-size: 14px; 
    font-weight: 700; 
    border: 1px solid #fecaca; 
}

/* Inputs Estilo Oscuro para que combine con el Glassmorphism */
.input-group { position: relative; margin-bottom: 25px; display: flex; align-items: center; }
.input-group input { 
    width: 100%; 
    padding: 16px 14px; 
    border-radius: 10px; 
    border: 1px solid #1E293B; 
    background: #0F172A; 
    color: white; 
    font-weight: 600; 
    outline: none; 
    transition: all 0.3s ease; 
    font-size: 1rem; 
}
.input-group input:focus { border-color: #0EA5E9; box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1); }

.input-group label { 
    position: absolute; 
    left: 14px; 
    top: 16px; 
    color: #94a3b8; 
    font-size: 14px; 
    transition: all 0.3s ease; 
    pointer-events: none; 
}
/* Etiqueta Flotante */
.input-group input:focus + label, .input-group input:not(:placeholder-shown) + label { 
    top: -8px; 
    left: 12px; 
    background: #0F172A; 
    padding: 0 6px; 
    font-size: 12px; 
    color: #0EA5E9; 
    font-weight: 700; 
    border-radius: 4px; 
}

/* Validación Visual */
.input-group input.is-invalid { border-color: #ef4444; box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1); }
.input-group input.is-valid { border-color: #10b981; box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1); }

/* Ojo de Contraseña SVG */
.toggle-password { 
    position: absolute; 
    right: 15px; 
    cursor: pointer; 
    color: #94a3b8; 
    transition: color 0.3s ease; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    width: 24px; 
    height: 24px; 
}
.toggle-password:hover { color: #0EA5E9; }

/* Botón Principal */
.btn-login { 
    width: 100%; 
    padding: 16px; 
    background: #0EA5E9; 
    border: none; 
    border-radius: 10px; 
    color: white; 
    font-weight: 800; 
    font-size: 16px; 
    cursor: pointer; 
    transition: all 0.3s ease; 
    margin-top: 5px; 
    text-transform: uppercase; 
    letter-spacing: 1px; 
}
.btn-login:hover { background: #0284c7; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(14, 165, 233, 0.3); }
.btn-login.loading { opacity: 0.7; cursor: not-allowed; }

.separador { 
    margin: 25px 0; 
    display: flex; 
    align-items: center; 
    color: #94A3B8; 
    font-size: 12px; 
    font-weight: 700; 
    text-transform: uppercase; 
}
.separador::before, .separador::after { content: ''; flex: 1; border-bottom: 1px solid #1E293B; }
.separador::before { margin-right: 1em; } 
.separador::after { margin-left: 1em; }

/* Botón de Google centrado e integrado */
.google-btn-wrapper { margin-bottom: 20px; display: flex; justify-content: center; transition: transform 0.3s ease; }
.google-btn-wrapper:hover { transform: scale(1.02); }

.footer-links a { color: #0EA5E9; text-decoration: none; font-weight: 700; display: inline-block; margin-top: 10px; font-size: 0.95rem; transition: color 0.3s; }
.footer-links a:hover { color: #0284c7; text-decoration: underline; }
.no-cuenta { color: #94a3b8; margin-top: 20px; font-size: 0.95rem; }

/* --- RESPONSIVIDAD CORREGIDA --- */
@media(max-width: 900px) { 
    body { overflow-y: auto; height: auto; min-height: 100vh; }
    .left-side { display: none; } 
    /* Cambiamos align-items a flex-start y damos 90px de espacio superior para no empalmar */
    .right-side { padding: 90px 20px 40px 20px; width: 100%; align-items: flex-start; }
    /* Agregamos margin: 0 auto para asegurar que siga centrado horizontalmente */
    .login-card { max-width: 420px; padding: 45px 30px; margin: 0 auto; }
    .btn-regresar { top: 20px; left: 20px; }
}

@media(max-width: 480px) {
    .login-card { padding: 35px 20px; border-radius: 16px; margin: 0 auto; }
    .form-title { font-size: 1.7rem; }
    .input-group input { padding: 14px 12px; }
    .btn-login { padding: 14px; }
}
</style>
</head>
<body>

<a href="/" class="btn-regresar">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
    </svg>
    Regresar
</a>

<div class="main-split">
    <div class="left-side">
        <h1>BIENVENIDO</h1>
        <p>En IMC+ tu progreso es importante. Mantén tu sesión activa para consultar tu historial y mejorar tu salud.</p>
    </div>
    <div class="right-side">
        <div class="login-card">
            <h2 class="form-title">Iniciar sesión</h2>
            <p class="subtitle-text">Accede a tu cuenta IMC+</p>
            
            <% if (error) { %>
            <div class="error-alert">⚠️ <%= error %></div>
            <% } %>
            
            <form action="/auth" method="POST" id="loginForm">
                <div class="input-group">
                    <input type="email" name="email" id="emailInput" placeholder=" " required>
                    <label>Correo electrónico</label>
                </div>
                <div class="input-group">
                    <input type="password" name="password" id="passwordInput" placeholder=" " required>
                    <label>Contraseña</label>
                    <div class="toggle-password" id="togglePassword">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                        </svg>
                        <svg id="eyeSlashIcon" style="display: none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l-.708.709z"/>
                            <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
                            <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/>
                        </svg>
                    </div>
                </div>
                <button type="submit" class="btn-login" id="submitBtn">Ingresar a IMC+</button>
            </form>
            
            <div class="separador">Otras formas de iniciar sesión</div>
            
            <div id="g_id_onload" data-client_id="996749304935-mav75khojhn4ibjasoglbj0iilmko4o6.apps.googleusercontent.com" data-context="signin" data-ux_mode="popup" data-callback="handleCredentialResponse" data-auto_prompt="false"></div>
            <div class="google-btn-wrapper">
                <div class="g_id_signin" data-type="standard" data-shape="rectangular" data-theme="filled_black" data-text="signin_with" data-size="large" data-logo_alignment="left"></div>
            </div>
            
            <div class="footer-links">
                <a href="/recuperar">¿Has olvidado tu contraseña?</a>
                <div class="no-cuenta">¿No tienes cuenta? <a href="/registro" style="color:#0EA5E9; font-weight: 800;">Regístrate</a></div>
            </div>
        </div>
    </div>
</div>

<script>
// Manejo del Login con Google
function handleCredentialResponse(response) {
    fetch('/auth-google', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: response.credential })
    })
    .then(res => { if (res.ok) window.location.href = '/'; else alert("Error en la autenticación."); })
    .catch(err => console.error("Error:", err));
}

// Mostrar/Ocultar Contraseña con íconos SVG
const togglePassword = document.getElementById('togglePassword');
const passwordInput = document.getElementById('passwordInput');
const eyeIcon = document.getElementById('eyeIcon');
const eyeSlashIcon = document.getElementById('eyeSlashIcon');

togglePassword.addEventListener('click', function () {
    const isPassword = passwordInput.getAttribute('type') === 'password';
    
    if(isPassword) {
        passwordInput.setAttribute('type', 'text');
        eyeIcon.style.display = 'none';
        eyeSlashIcon.style.display = 'block';
    } else {
        passwordInput.setAttribute('type', 'password');
        eyeIcon.style.display = 'block';
        eyeSlashIcon.style.display = 'none';
    }
});

// Validación visual de Email y Loading Spinner
const emailInput = document.getElementById('emailInput');
const loginForm = document.getElementById('loginForm');
const submitBtn = document.getElementById('submitBtn');

emailInput.addEventListener('input', function() {
    if (this.value.length > 0) {
        if (this.value.includes('@') && this.value.includes('.')) {
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        } else {
            this.classList.remove('is-valid');
            this.classList.add('is-invalid');
        }
    } else {
        this.classList.remove('is-valid', 'is-invalid');
    }
});

loginForm.addEventListener('submit', function() {
    submitBtn.classList.add('loading');
    submitBtn.innerText = 'Cargando...';
});
</script>
</body>
</html>